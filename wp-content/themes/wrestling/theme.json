{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "primary", "color": "#1a1a2e", "name": "Primary Dark" },
        { "slug": "accent",  "color": "#c8a951", "name": "Accent Gold" },
        { "slug": "light",   "color": "#f5f5f5", "name": "Light" },
        { "slug": "white",   "color": "#ffffff", "name": "White" },
        { "slug": "text",    "color": "#222222", "name": "Text" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "system-ui, -apple-system, sans-serif",
          "slug": "system",
          "name": "System"
        }
      ]
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#222222"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system)",
      "fontSize": "1rem",
      "lineHeight": "1.6"
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
